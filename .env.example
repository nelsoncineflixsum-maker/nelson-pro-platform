# Nelson Pro Platform - Configurações de Ambiente

# Porta do servidor
PORT=3000

# URL do MongoDB (local ou cloud)
# Para MongoDB local:
MONGODB_URI=mongodb://localhost:27017/nelson-pro-platform

# Para MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/nelson-pro-platform

# Chave secreta para JWT (ALTERE PARA UMA CHAVE FORTE EM PRODUÇÃO!)
JWT_SECRET=nelson-pro-2024-super-secret-key-change-this-in-production

# Tempo de expiração do token (exemplos: '1h', '7d', '30d')
JWT_EXPIRE=7d

# Ambiente (development ou production)
NODE_ENV=development

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Configurações de email (opcional - para recuperação de senha)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=seu-email@gmail.com
# EMAIL_PASSWORD=sua-senha-de-app
# EMAIL_FROM=noreply@nelsonpro.com
